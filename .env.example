MAIL_DOMAIN=
MAIL_WORKER_BASE=
MAIL_ADMIN_PASSWORD=
TOKEN_OUTPUT_DIR=./tokens
CLI_PROXY_AUTHS_DIR=

# 代理配置 (二选一)
# 单代理: 直接填写代理地址
# PROXY=http://127.0.0.1:7890
# 多代理文件: 指向 proxies.txt，批量注册时自动轮换
PROXY_FILE=proxies.txt

# Resin 粘性代理配置 (启用后整个注册流程使用同一个出口 IP)
# RESIN_URL: Resin 网关地址，格式 http://token@host:port
RESIN_URL=
# RESIN_PLATFORM: Resin Platform 名称（默认: Default）
RESIN_PLATFORM=Default
# RESIN_STICKY: 设为 true 启用粘性代理
RESIN_STICKY=false

# 批量注册配置
# BATCH_COUNT=10
# BATCH_THREADS=1

# 邮箱模式: file=从accounts.txt读取, cf=Cloudflare自有域名, hotmail007=API拉取微软邮箱, luckmail=API接码平台
EMAIL_MODE=luckmail
ACCOUNTS_FILE=accounts.txt

# ==========================================
# Cloudflare Worker 模式配置 (EMAIL_MODE=cf 时启用)
# ==========================================
MAIL_DOMAIN=your-domain.com
MAIL_WORKER_BASE=https://mail-worker.your-domain.com
MAIL_ADMIN_PASSWORD=your-password

# ==========================================
# Hotmail007 模式配置 (EMAIL_MODE=hotmail007 时启用)
# ==========================================
HOTMAIL007_API_URL=https://gapi.hotmail007.com
HOTMAIL007_API_KEY=你的API密钥
HOTMAIL007_MAIL_TYPE=hotmail Trusted Graph
HOTMAIL007_MAIL_MODE=imap

# ==========================================
# LuckMail 模式配置 (EMAIL_MODE=luckmail 时启用)
# ==========================================
LUCKMAIL_API_URL=https://mails.luckyous.com/api/v1/openapi
LUCKMAIL_API_KEY=你的API密钥
# 邮箱类型: ms_imap (IMAP协议) 或 ms_graph (Microsoft Graph API)
LUCKMAIL_EMAIL_TYPE=ms_imap
# 是否启用自动购买邮箱（true=购买并检测活跃度，false=使用接码模式）
# 启动时会优先检查已购的非禁用邮箱，检测活跃度后加入号池
LUCKMAIL_AUTO_BUY=true
# 只使用已购邮箱模式（true=只用已购邮箱，用完停止；false=允许购买新邮箱）
# 适合已有大量邮箱的用户，不购买新邮箱，用完即停
LUCKMAIL_PURCHASED_ONLY=false
# 跳过已购邮箱检查（true=跳过已购邮箱直接购买新邮箱；false=先检查已购邮箱）
# 预检测模式默认开启，实时购买模式默认关闭
LUCKMAIL_SKIP_PURCHASED=false
# 已购/预检测邮箱活跃度检测并发数
# 已购邮箱模式默认只筛选 @hotmail.com，并把检测通过的邮箱立即加入号池
LUCKMAIL_CHECK_WORKERS=20
# 调试 LuckMail 收信轮询（打印 token/mails 返回摘要、最近邮件主题、fallback 状态）
LUCKMAIL_MAIL_DEBUG=false
# 邮箱不活跃时的最大重试次数
LUCKMAIL_MAX_RETRY=3
